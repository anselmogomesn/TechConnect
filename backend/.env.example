# ============================================
# TechConnect - Environment Variables Example
# ============================================
# Copy this file to .env and adjust values

# Server
NODE_ENV=development
PORT=3000
HOST=localhost

# Database (SQLite for dev / PostgreSQL for prod)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/anselmo?schema=public"

# JWT
JWT_SECRET=change-this-to-a-random-string
JWT_REFRESH_SECRET=change-this-to-another-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=change-this-cookie-secret

# CORS
CORS_ORIGIN=http://localhost:5173

# Upload
UPLOAD_DIR=../uploads
MAX_FILE_SIZE=10485760

# Email
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@techconnect.com

# Rate Limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5

# Security
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_DURATION_MINUTES=15
